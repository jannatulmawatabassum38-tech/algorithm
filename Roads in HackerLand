struct DSU {
    vector<int> parent, rank;
    DSU(int n) {
        parent.resize(n + 1);
        rank.resize(n + 1, 0);
        for (int i = 1; i <= n; i++) parent[i] = i;}
    int find(int i) {
        if (parent[i] == i) return i;
        return parent[i] = find(parent[i]); }
    bool unite(int i, int j) {
        int root_i = find(i);
        int root_j = find(j);
        if (root_i != root_j) {
            if (rank[root_i] < rank[root_j]) swap(root_i, root_j);
            parent[root_j] = root_i;
            if (rank[root_i] == rank[root_j]) rank[root_i]++;
            return true; }
        return false; }};
int dfs(int u, int p, int edge_idx, int n, const vector<vector<pair<int, int>>>& adj, vector<long long>& edge_count) {
    int subtree_size = 1;
    for (const auto& edge : adj[u]) {
        int v = edge.first;
        int idx = edge.second;
        if (v != p) {
            subtree_size += dfs(v, u, idx, n, adj, edge_count); }}
    if (edge_idx != -1) {
        edge_count[edge_idx] = (long long)subtree_size * (n - subtree_size); }
    return subtree_size;}
string roadsInHackerLand(int n, vector<vector<int>> roads) {
    int m = roads.size();
    vector<vector<int>> indexed_roads(m);
    for (int i = 0; i < m; i++) {
        indexed_roads[i] = {roads[i][2], roads[i][0], roads[i][1]};}
    sort(indexed_roads.begin(), indexed_roads.end());
    DSU dsu(n);
    vector<vector<pair<int, int>>> adj(n + 1);
    for (int i = 0; i < m; i++) {
        int w = indexed_roads[i][0];
        int u = indexed_roads[i][1];
        int v = indexed_roads[i][2];
        if (dsu.unite(u, v)) {
            adj[u].push_back({v, w});
            adj[v].push_back({u, w});} }
    vector<long long> edge_count(m, 0);
    dfs(1, 0, -1, n, adj, edge_count);
    vector<long long> binary_sum(2 * m + 60, 0);
    for (int i = 0; i < m; i++) {
        binary_sum[i] = edge_count[i];}
    long long carry = 0;
    string result = "";
    for (int i = 0; i < binary_sum.size(); i++) {
        long long current = binary_sum[i] + carry;
        binary_sum[i] = current % 2;
        carry = current / 2;}
    int last_one = -1;
    for (int i = binary_sum.size() - 1; i >= 0; i--) {
        if (binary_sum[i] == 1) {
            last_one = i;
            break;} }
    if (last_one == -1) return "0";
    for (int i = last_one; i >= 0; i--) {
        result += to_string(binary_sum[i]); }
    return result;}
